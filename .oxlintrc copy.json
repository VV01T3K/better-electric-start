{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": [
		"react",
		"react-perf",
		"typescript",
		"import",
		"unicorn",
		"jsx-a11y",
		"vitest",
		"promise",
		"oxc"
	],
	"jsPlugins": ["@tanstack/eslint-plugin-query"],
	"categories": {
		"correctness": "error",
		"suspicious": "warn"
	},
	"rules": {
		// TanStack Query recommended rules
		"@tanstack/query/exhaustive-deps": "error",
		"@tanstack/query/no-rest-destructuring": "warn",
		"@tanstack/query/stable-query-client": "error",
		"@tanstack/query/no-unstable-deps": "warn",
		"@tanstack/query/infinite-query-property-order": "error",

		// React 17+ JSX transform doesn't require React import
		"react/react-in-jsx-scope": "off",

		// TanStack Router Link uses "to" prop, not "href" - oxlint doesn't support this yet
		"jsx-a11y/anchor-is-valid": "off",

		// Warn when click handlers lack keyboard alternatives (accessibility)
		"jsx-a11y/click-events-have-key-events": "warn",

		// Warn on unsafe type assertions to catch potential runtime errors
		"@typescript-eslint/no-unsafe-type-assertion": "warn",

		// Error on deprecated API usage
		"@typescript-eslint/no-deprecated": "error",

		// Warn on using "new" without assignment (side-effect constructors)
		"eslint/no-new": "warn",

		// backend-specific
		"eslint/no-console": "warn",

		// ui-shadcn-specific
		"jsx-a11y/label-has-associated-control": "off",

		//temporarily disable some rules while we fix existing issues
		"@typescript-eslint/no-floating-promises": "off"
	},
	"settings": {
		"jsx-a11y": {
			// Support polymorphic components (e.g., <Button as="a">)
			"polymorphicPropName": "as"
		},
		"vitest": {
			"typecheck": true
		}
	},
	"ignorePatterns": [
		"node_modules",
		"dist",
		".output",
		"**/*.gen.*",
		".claude/**",
		".agents/**",
		".cursor/**",
		".turbo",
		"**/routeTree.gen.ts",
		"**/bun.lock",
		"**/_generated/**",
		"**/betterAuth/generatedSchema.ts"
	]
}
