{
	"name": "my-tanstack-app",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "bun --bun vite dev --port 3000 --host",
		"build": "bun type && bun --bun vite build",
		"preview": "bun --bun vite preview",
		"type": "tsgo --noEmit",
		"check": "bun oxfmt --check && bun oxlint",
		"fix": "bun oxfmt && bun oxlint --fix",
		"test": "varlock run -- bun --bun vitest run",
		"prepare": "lefthook install",
		"postinstall": "bunx skills experimental_install",
		"auth:gen": "varlock run -- mise exec -- npm exec --yes --package=https://pkg.pr.new/better-auth/better-auth/%40better-auth%2Fcli@627eccb7cfe89e4cd8172c5401513d4fb6a5efbb -- better-auth generate --config ./src/integrations/better-auth/config.ts -y --output ./src/db/tables/auth.gen.ts",
		"db:gen": "varlock run -- bun --bun drizzle-kit generate",
		"db:migrate": "varlock run -- bun --bun drizzle-kit migrate",
		"db:push": "varlock run -- bun --bun drizzle-kit push",
		"db:pull": "varlock run -- bun --bun drizzle-kit pull",
		"db:studio": "varlock run -- bun --bun drizzle-kit studio"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "https://pkg.pr.new/better-auth/better-auth/@better-auth/drizzle-adapter@6913",
		"@electric-sql/client": "^1.5.13",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/electric-db-collection": "^0.2.41",
		"@tanstack/eslint-plugin-query": "^5.95.2",
		"@tanstack/query-db-collection": "latest",
		"@tanstack/react-db": "^0.1.77",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-form": "latest",
		"@tanstack/react-query": "5.95.2",
		"@tanstack/react-query-devtools": "5.95.2",
		"@tanstack/react-router": "1.168.3",
		"@tanstack/react-router-devtools": "1.166.11",
		"@tanstack/react-router-ssr-query": "1.166.10",
		"@tanstack/react-start": "1.167.6",
		"@tanstack/router-plugin": "^1.167.3",
		"@varlock/vite-integration": "^0.2.7",
		"better-auth": "^1.5.6",
		"drizzle-kit": "^1.0.0-beta.19",
		"drizzle-orm": "^1.0.0-beta.19",
		"lucide-react": "^1.6.0",
		"nitro": "npm:nitro-nightly@3.0.1-20260324-103046-9ce219ca",
		"pg": "^8.16.3",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwindcss": "^4.2.2",
		"varlock": "^0.6.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@rolldown/plugin-babel": "^0.2.2",
		"@tailwindcss/typography": "^0.5.16",
		"@tanstack/devtools-vite": "latest",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^25.5.0",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@typescript/native-preview": "^7.0.0-dev.20260324.1",
		"@vitejs/plugin-react": "^6.0.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"happy-dom": "^20.0.8",
		"lefthook": "^2.1.4",
		"oxfmt": "^0.42.0",
		"oxlint": "^1.57.0",
		"oxlint-tsgolint": "^0.17.4",
		"tsx": "^4.21.0",
		"vite": "^8.0.2",
		"vitest": "^4.1.1"
	},
	"packageManager": "bun@1.3.11"
}
