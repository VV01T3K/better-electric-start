{
  "name": "my-tanstack-app",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun --bun vite dev --port 3000 --host",
    "build": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "test": "varlock run -- bun --bun vitest run",
    "type": "varlock run -- mise exec -- bunx tsc --noEmit",
    "db:generate": "varlock run -- drizzle-kit generate",
    "db:migrate": "varlock run -- drizzle-kit migrate",
    "db:push": "varlock run -- drizzle-kit push",
    "db:pull": "varlock run -- drizzle-kit pull",
    "db:studio": "varlock run -- drizzle-kit studio"
  },
  "dependencies": {
    "@electric-sql/client": "^1.5.13",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/electric-db-collection": "^0.2.41",
    "@tanstack/query-db-collection": "latest",
    "@tanstack/react-db": "^0.1.77",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-query": "5.95.0",
    "@tanstack/react-query-devtools": "5.95.0",
    "@tanstack/react-router": "1.168.2",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/react-router-ssr-query": "1.166.10",
    "@tanstack/react-start": "1.167.3",
    "@tanstack/router-plugin": "^1.167.3",
    "@varlock/vite-integration": "^0.2.7",
    "better-auth": "^1.5.6",
    "drizzle-kit": "1.0.0-beta.17-67b1795",
    "drizzle-orm": "1.0.0-beta.17-67b1795",
    "lucide-react": "^0.577.0",
    "nitro": "npm:nitro-nightly@3.0.1-20260322-095631-ffdd706a",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.2",
    "varlock": "^0.6.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  },
  "packageManager": "bun@1.3.11"
}
